programa
{
	
	funcao inicio()
	{
		inteiro ano

		escreva("Qual o Ano?\n")

		leia(ano)

		limpa()

	     se 
	     	(ano % 4 == 0 e ano % 100 != 0 ou ano % 400 == 0) escreva("O ano é bissexto")
	      
	     senao
	     	escreva("O ano não é bissexto")
	}
}
