programa
{
	
	funcao inicio()
	{
		inteiro idade
		
			escreva("Insira a idade: ")

			leia(idade)
			
			limpa()

		se (idade <= 2)
		
		{
			
			escreva("Passagem gratuita")
		}
		
		
		senao se (idade >= 3 e idade <= 12)
		
		{
			
			escreva("Meia Tarifa")
		}
		
		senao
		{
			
			escreva("Tarifa Completa")
			
		}
			

	}
}
