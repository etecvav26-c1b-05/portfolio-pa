programa
{
	
	funcao inicio()
	
	{
		inteiro numeroA, numeroB, numeroC, maior
		
			escreva("Insira o primeiro numero: ")
			
			leia(numeroA)
			
			limpa()
			

			escreva("Insira o segundo numero: ")
			
			leia(numeroB)
			
			limpa()
			

			escreva("Insira o terceiro numero: ")
			
			leia(numeroC)
			
			limpa()

		maior = numeroA

		se
			(numeroB >  maior)
		{
			maior = numeroB
		}
		se 
			(numeroC > maior)
		{
			maior = numeroC
		}

		escreva("Maior numero: " + maior)
		
	}
}
